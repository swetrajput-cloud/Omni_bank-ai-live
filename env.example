# ══════════════════════════════════════════════════════════
# OmniBank AI — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.
# ══════════════════════════════════════════════════════════

# ── Twilio ─────────────────────────────────────────────────
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1415XXXXXXX   # Your Twilio number (with country code)

# ── Your public backend URL ────────────────────────────────
# Twilio needs a public HTTPS URL to send webhooks to.
# Options:
#   1. Deploy to Railway → set to https://yourapp.up.railway.app
#   2. Local dev → use ngrok: ngrok http 8000 → set to https://xxxx.ngrok.io
BACKEND_URL=https://your-railway-app.up.railway.app

# ── Gmail ──────────────────────────────────────────────────
# The Gmail address to monitor for incoming emails
GMAIL_ADDRESS=your-bank-email@gmail.com
# How often to poll Gmail (seconds)
GMAIL_POLL_INTERVAL=30

# ── Optional: Anthropic Claude API ────────────────────────
# Uncomment to enable LLM-powered responses instead of rule-based
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
